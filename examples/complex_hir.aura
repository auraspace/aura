class Point {
  x: i32;
  y: i32;

  function constructor(x: i32, y: i32): void {
    this.x = x;
    this.y = y;
  }

  function add(other: Point): void {
    this.x = this.x + other.x;
    this.y = this.y + other.y;
  }
}

function main(): void {
  let p = new Point(10, 20);
  p.add(new Point(1, 1));
}
