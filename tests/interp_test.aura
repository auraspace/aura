function fib(n: i32): i32 {
    if (n <= 1) {
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}

print("Fibonacci of 10:");
print(fib(10));

class Point {
    x: i32;
    y: i32;
    constructor(x: i32, y: i32) {
        this.x = x;
        this.y = y;
    }
    function sum(): i32 {
        return this.x + this.y;
    }
}

let p: Point = new Point(10, 20);
print("Point sum:");
print(p.sum());

p.x = 100;
print("Updated Point sum:");
print(p.sum());
