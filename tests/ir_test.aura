class Point {
    x: i32;
    y: i32;

    constructor(x: i32, y: i32) {
        this.x = x;
        this.y = y;
    }

    function sum(): i32 {
        return this.x + this.y;
    }
}

let p = new Point(10, 20);
print(p.sum());

let s = "Hello SSA IR";
print(s);

if (10 < 20) {
    print("Correct");
} else {
    print("Wrong");
}
