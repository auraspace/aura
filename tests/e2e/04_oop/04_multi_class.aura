// Test: Multiple classes referencing each other
// Expected output:
// 3
// 4
// 5

class Vec2 {
  public x: i32;
  public y: i32;

  public constructor(x: i32, y: i32) {
    this.x = x;
    this.y = y;
  }
}

class Triangle {
  public a: i32;
  public b: i32;
  public c: i32;

  public constructor(a: i32, b: i32, c: i32) {
    this.a = a;
    this.b = b;
    this.c = c;
  }

  public sides(): i32 {
    return this.a + this.b + this.c;
  }
}

let v = new Vec2(3, 4);
print v.x;
print v.y;

let t = new Triangle(3, 4, 5);

// sides: 3+4+5 = 12, but we print the perimeter / 4 won't work without div
// Let's print sides()
print t.c;
