// Expected output:
// Woof!
// Barking...

abstract class Animal {
  public abstract makeSound(): void;

  public move(): void {
    print "Moving...";
  }
}

class Dog extends Animal {
  public override makeSound(): void {
    print "Woof!";
  }
}

let dog = new Dog();
dog.makeSound();

// Test abstract method implementation in a chain
abstract class Mammal extends Animal {
  public abstract breathe(): void;
}

class Human extends Mammal {
  public override makeSound(): void {
    print "Hello!";
  }

  public override breathe(): void {
    print "Breathing...";
  }
}

// Test multiple abstract methods
abstract class Shape {
  public abstract area(): i32;

  public abstract perimeter(): i32;
}

class Square extends Shape {
  private side: i32;

  public constructor(side: i32) {
    this.side = side;
  }

  public override area(): i32 {
    return this.side * this.side;
  }

  public override perimeter(): i32 {
    return 4 * this.side;
  }
}

// Verification of errors (these should fail compilation, but we test the positive case here)
// let a = new Animal(); // Error: Cannot instantiate abstract class 'Animal'

print "Barking...";
