// Expected output:
// Woof!

class Animal {
    speak(): string {
        return "Generic animal sound";
    }
}

class Dog extends Animal {
    override speak(): string {
        return "Woof!";
    }
}

function makeItSpeak(a: Animal) {
    print a.speak();
}

let d = new Dog();
makeItSpeak(d); // Outputs: Woof!
