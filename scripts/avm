#!/usr/bin/env bash
# avm — Aura Version Manager
# Switch the active toolchain under $AURA_HOME (default ~/.aura).
# Source of truth for install.sh embed (site/scripts/sync-install.mjs).
#
# Note: avoid large heredocs inside functions — some bash builds hang on them
# (same constraint as scripts/install.sh write_avm).
set -euo pipefail
AURA_HOME="${AURA_HOME:-${HOME}/.aura}"
die() { printf 'error: %s\n' "$*" >&2; exit 1; }

valid_install() {
  local target="$1" version
  [[ -d "$target" && -x "$target/bin/aura" ]] || return 1
  [[ -s "$target/meta/version" && -s "$target/meta/os" && -s "$target/meta/arch" ]] || return 1
  version="$(sed -n '1p' "$target/meta/version")"
  [[ "$version" == "$(basename "$target")" ]] || return 1
}

version_target() {
  local version="$1"
  [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.-]+)?$ ]] || return 1
  printf '%s\n' "${AURA_HOME}/versions/${version}"
}

list_versions() {
  local d
  [[ -d "${AURA_HOME}/versions" ]] || return 0
  for d in "${AURA_HOME}/versions"/*/; do
    [[ -d "$d" ]] || continue
    valid_install "$d" && basename "$d"
  done | sort
}

show_current() {
  if [[ -L "${AURA_HOME}/current" ]]; then
    local target version
    target="$(readlink "${AURA_HOME}/current" 2>/dev/null || true)"
    version="$(basename "$target")"
    if [[ "$target" == versions/* ]] && valid_install "${AURA_HOME}/${target}"; then
      printf '%s\n' "$version"
    else
      printf '(none)\n'
    fi
  elif [[ -d "${AURA_HOME}/current" ]]; then
    printf '(none)\n'
  else
    printf '(none)\n'
  fi
}

usage() {
  printf '%s\n' \
    'avm — Aura Version Manager' \
    '' \
    'Switch the active Aura toolchain under $AURA_HOME (default: ~/.aura).' \
    'Does not download; only flips the current symlink among installed trees.' \
    '' \
    'Usage:' \
    '  avm <version>     Activate an installed version (leading v is optional)' \
    '  avm --list, -l    List installed versions under $AURA_HOME/versions/' \
    '  avm --show, -s    Print the active version (or "(none)")' \
    '  avm --help, -h    Show this help' \
    '' \
    'Environment:' \
    '  AURA_HOME         Toolchain root (default: $HOME/.aura)' \
    '' \
    'Examples:' \
    '  avm --list' \
    '  avm --show' \
    '  avm 0.1.0-alpha' \
    '  AURA_HOME=/opt/aura avm 0.2.0' \
    '' \
    'Install a version first:' \
    '  curl -fsSL https://aura.fadosoft.com/install.sh | AURA_VERSION=0.1.0-alpha bash' \
    '' \
    'PATH: put $AURA_HOME/bin (or ~/.local/bin after install) ahead of other aura binaries.' \
    'Verify:  scripts/install-smoke.sh   (see docs/guide/install.md)'
}

cmd="${1:-}"
case "$cmd" in
  ""|-h|--help)
    usage
    exit 0
    ;;
  --list|-l)
    list_versions
    exit 0
    ;;
  --show|-s)
    show_current
    exit 0
    ;;
  -*)
    die "unknown option: $cmd
Run: avm --help"
    ;;
esac

ver="${cmd#v}"
if ! target="$(version_target "$ver")"; then
  die "invalid version: ${ver} (expected semver such as 0.1.0-alpha)"
fi
if ! valid_install "$target"; then
  die "version not installed: ${ver}
The installation is missing its executable or metadata and cannot be activated.
Install with:
  curl -fsSL https://aura.fadosoft.com/install.sh | AURA_VERSION=${ver} bash
Available:
$(list_versions | sed 's/^/  /' || true)
Run: avm --help"
fi

mkdir -p "${AURA_HOME}/bin"
if [[ -e "${AURA_HOME}/current" && ! -L "${AURA_HOME}/current" ]]; then
  die "refusing to replace malformed non-symlink: ${AURA_HOME}/current"
fi
if [[ -e "${AURA_HOME}/bin/aura" && ! -L "${AURA_HOME}/bin/aura" ]]; then
  die "refusing to replace non-symlink: ${AURA_HOME}/bin/aura"
fi
# Relative symlinks so AURA_HOME can be relocated as a tree.
current_tmp="${AURA_HOME}/.current.tmp.$$"
aura_tmp="${AURA_HOME}/bin/.aura.tmp.$$"
rm -f "$current_tmp" "$aura_tmp"
ln -s "versions/${ver}" "$current_tmp"
ln -s "../current/bin/aura" "$aura_tmp"
mv -f "$current_tmp" "${AURA_HOME}/current"
mv -f "$aura_tmp" "${AURA_HOME}/bin/aura"
printf 'active: %s\n' "$ver"
if [[ -x "${AURA_HOME}/bin/aura" ]]; then
  "${AURA_HOME}/bin/aura" version || true
fi
