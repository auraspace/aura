// Nullability + flow narrowing + !!
package demo.types

fun label(name: String?): String {
  if (name != null) {
    return name
  } else {
    return "anonymous"
  }
}

fun label_eq(name: String?): String {
  if (name == null) {
    return "anonymous"
  } else {
    return name
  }
}

fun force(name: String?): String {
  return name!!
}

fun main() {
  println(label("Hello, Aura"))
  println(label(null))
  println(label_eq("ok"))
  println(force("force"))
}
