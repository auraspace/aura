// Async task joins return std.io.Result<T, String> instead of aborting.
package demo.task_outcome

import std.io as Io

async fun answer(): Int {
  return 7
}

fun main() {
  val task = spawn { val value: Int = await answer() return }
  val outcome: Io.Result<Unit, String> = join(task)
  match (outcome) {
    case Ok(value) => { Io.println("unexpected success") }
    case Err(error) => { Io.println(error) }
  }
}
