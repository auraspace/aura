// Library package — only `pub` items are usable by importers.
package demo.math

pub fun square(x: Int): Int {
  return mul(x, x)
}

// Private helper — not visible outside this package.
fun mul(a: Int, b: Int): Int {
  return a * b
}

// C3u — type qualify via `import … as Alias` → `Alias.Point`
pub class Point(val x: Int, val y: Int) {
  fun sum(): Int {
    return this.x + this.y
  }
}
