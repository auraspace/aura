// std.io — console + file I/O (runtime intrinsics).

package std.io

/// Terminal outcome for an asynchronous task join.
pub enum TaskError {
  case Failed(error: String)
  case Cancelled
}

/// Non-throwing result used by task joins and structured file wrappers below.
/// Error strings are owned Aura Strings; callers may retain or return them.
pub enum Result<T, E> {
  case Ok(value: T)
  case Err(error: E)
}

/// Process argument vector as `Array<String>`.
/// `args()[0]` is the program name (`argv[0]`); user flags start at index 1.
/// Values are process-lifetime views of the OS argv (not independent copies).
pub fun args(): Array<String> {
  // Body replaced by codegen: Array from runtime-stashed argc/argv.
  return Array(0)
}

