/// Soft read: same content rules as `readFile`, but returns `null` on missing
/// path, I/O error, oversized file (>256 MiB), empty path, OOM, or embedded NUL.
/// Prefer this when absence / soft failure is expected; use `readFile` to throw.
pub fun tryReadFile(path: String): String? {
  // Body replaced by codegen with aura_try_read_file(path).
  return null
}

/// Write `content` to `path`, creating or truncating the file.
/// Throws on I/O error.
pub fun writeFile(path: String, content: String) {
  // Body replaced by codegen with aura_write_file(path, content).
}

/// Soft write: create/truncate `path` with `content`. Returns `true` on success;
/// `false` on empty path, open/write/flush/close failure (does not throw).
/// Prefer this when soft failure is expected; use `writeFile` to throw.
pub fun tryWriteFile(path: String, content: String): Bool {
  // Body replaced by codegen with aura_try_write_file(path, content).
  return false
}

/// Non-throwing read with an explicit owned error payload.
/// `Ok` contains the same owned String as `tryReadFile`; `Err` contains a
/// fresh String describing the failed operation. Existing readFile and
/// tryReadFile behavior is unchanged.
pub fun readFileResult(path: String): Result<String, String> {
  val content = tryReadFile(path)
  if (content == null) {
    return Err("readFile failed: " + path)
  }
  return Ok(content!!)
}

/// Non-throwing write with an explicit owned error payload.
/// `Ok(true)` indicates that the file was fully written and closed; `Err`
/// contains a fresh String describing the failed operation.
pub fun writeFileResult(path: String, content: String): Result<Bool, String> {
  if (tryWriteFile(path, content)) {
    return Ok(true)
  }
  return Err("writeFile failed: " + path)
}

