/**
 * Base class for all errors in Aura.
 * This report error "Duplicate declaration: Error" because in compiler, it was declared in std/core.aura and. Ignore it.
 */
class Error {
  public message: string;

  /**
   * Creates a new Error with the given message.
   */
  public constructor(message: string) {
    this.message = message;
  }

  /**
   * Returns the error message.
   */
  public toString(): string {
    return this.message;
  }
}
